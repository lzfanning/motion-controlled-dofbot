[Unit]
Description=Dofbot Motion Control Service
After=network.target

[Service]
User=dofbot
WorkingDirectory=/home/dofbot/motion-controlled-dofbot
ExecStart=/usr/bin/python3 /home/dofbot/motion-controlled-dofbot/dofbot_motion_control_service.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
